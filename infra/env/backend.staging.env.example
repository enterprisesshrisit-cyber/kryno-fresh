APP_ENV=production
PORT=8080
HOST=0.0.0.0

# Permanent staging API, never localhost or trycloudflare.
APP_BASE_URL=https://api-staging.kryno.example

# Supabase / managed Postgres.
DATABASE_URL=postgres://postgres:REPLACE_ME@db.PROJECT_REF.supabase.co:5432/postgres
DATABASE_SSL=true
# Keep true when your host trusts the database CA. Set false only if the
# managed pooler requires SSL but does not provide a locally trusted chain.
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Generate unique 64+ char secrets for each value.
JWT_ISSUER=kryno-auth
JWT_AUDIENCE=kryno-mobile
JWT_ACCESS_SECRET=REPLACE_WITH_64_PLUS_CHAR_RANDOM_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_PLUS_CHAR_RANDOM_SECRET
OTP_PEPPER=REPLACE_WITH_DIFFERENT_64_PLUS_CHAR_RANDOM_SECRET

ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
EMAIL_VERIFICATION_TTL_HOURS=24
EMAIL_OTP_TTL_MINUTES=10
RESET_PASSWORD_OTP_TTL_MINUTES=10
ALLOW_DEV_EMAIL_TOKEN_PREVIEW=false

# Transactional email. Use Resend, Postmark, SendGrid, Mailgun, or SES.
EMAIL_FROM=KRYNO Security <security@kryno.example>
SMTP_HOST=smtp.provider.example
SMTP_PORT=587
SMTP_SECURE=false
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_USER=REPLACE_ME
SMTP_PASS=REPLACE_ME
SECURITY_ALERT_EMAIL=security@kryno.example

# Redis / Upstash / managed Redis. Required for distributed rate limits.
REDIS_URL=rediss://default:REPLACE_ME@redis.provider.example:6379
REDIS_TLS=true

# Cloudflare WAF/CDN gate.
WAF_PROVIDER=cloudflare

# Cloudflare R2 / S3-compatible storage.
MEDIA_STORAGE_DRIVER=s3
R2_ACCOUNT_ID=REPLACE_ME
R2_ACCESS_KEY_ID=REPLACE_ME
R2_SECRET_ACCESS_KEY=REPLACE_ME
R2_BUCKET=kryno-staging-media
R2_PUBLIC_BASE_URL=https://media-staging.kryno.example
R2_REGION=auto

# Attachments stay encrypted before upload. Social media is trusted/public media.
MAX_ATTACHMENT_BYTES=15728640
MAX_SOCIAL_MEDIA_BYTES=20971520

# LiveKit managed calls. TURN is optional for raw WebRTC fallback.
LIVEKIT_URL=https://kryno-staging.livekit.cloud
LIVEKIT_API_KEY=REPLACE_ME
LIVEKIT_API_SECRET=REPLACE_ME
KRYNO_STUN_URLS=stun:stun.l.google.com:19302
KRYNO_TURN_URLS=
KRYNO_TURN_USERNAME=
KRYNO_TURN_CREDENTIAL=

# Billing.
REVENUECAT_WEBHOOK_SECRET=REPLACE_ME

# Monitoring.
SENTRY_DSN=https://PUBLIC_KEY@o000000.ingest.sentry.io/000000

# Link to the deployed/approved backup policy document.
BACKUP_POLICY_URL=https://docs.kryno.example/security/backup-recovery
