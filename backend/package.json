{
  "name": "kryno-auth-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:dist": "node dist/db/migrate.js",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "audit:prod": "npm audit --omit=dev",
    "secrets:generate": "tsx src/scripts/generate-production-secrets.ts",
    "security:staging-check": "tsx src/scripts/security-staging-check.ts",
    "test:smoke": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@fastify/cors": "^11.1.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "@sentry/node": "^10.53.1",
    "argon2": "^0.44.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.1",
    "ioredis": "^5.10.1",
    "jose": "^6.1.0",
    "livekit-server-sdk": "^2.15.3",
    "nodemailer": "^8.0.4",
    "pg": "^8.16.3",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/pg": "^8.15.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
