APP_ENV=production
HOST=0.0.0.0
PORT=8080

# Database
# Supabase Postgres, Neon, Railway Postgres, or managed Postgres.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Public API/app origin
# Must be permanent HTTPS in production. Do not use localhost or trycloudflare here.
APP_BASE_URL=https://api.kryno.example

# Auth tokens
# Generate unique high-entropy values, 48+ characters each.
JWT_ISSUER=kryno
JWT_AUDIENCE=kryno-mobile
JWT_ACCESS_SECRET=REPLACE_WITH_48_PLUS_RANDOM_CHARS_ACCESS_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_48_PLUS_RANDOM_CHARS_REFRESH_SECRET
OTP_PEPPER=REPLACE_WITH_48_PLUS_RANDOM_CHARS_OTP_PEPPER
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
EMAIL_VERIFICATION_TTL_HOURS=24
EMAIL_OTP_TTL_MINUTES=10
RESET_PASSWORD_OTP_TTL_MINUTES=10
ALLOW_DEV_EMAIL_TOKEN_PREVIEW=false

# Transactional email
EMAIL_FROM=KRYNO <no-reply@kryno.example>
EMAIL_PROVIDER=smtp
# Render and some clouds can block or throttle SMTP. Use resend, brevo, or postmark with an HTTP API key when SMTP times out.
RESEND_API_KEY=
BREVO_API_KEY=
POSTMARK_SERVER_TOKEN=
SMTP_HOST=smtp.provider.example
SMTP_PORT=587
SMTP_SECURE=false
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_USER=REPLACE_WITH_SMTP_USER
SMTP_PASS=REPLACE_WITH_SMTP_PASSWORD
SECURITY_ALERT_EMAIL=security@kryno.example

# Distributed rate limiting
REDIS_URL=rediss://default:REPLACE_WITH_REDIS_PASSWORD@redis.example.com:6379
REDIS_TLS=true

# WAF/CDN and backup policy
WAF_PROVIDER=cloudflare
BACKUP_POLICY_URL=https://docs.kryno.example/security/backup-recovery

# Calls
# LiveKit is the managed call layer. TURN is optional for raw WebRTC fallback.
KRYNO_STUN_URLS=stun:stun.l.google.com:19302
KRYNO_TURN_URLS=
KRYNO_TURN_USERNAME=
KRYNO_TURN_CREDENTIAL=
LIVEKIT_URL=https://livekit.kryno.example
LIVEKIT_API_KEY=REPLACE_WITH_LIVEKIT_API_KEY
LIVEKIT_API_SECRET=REPLACE_WITH_LIVEKIT_API_SECRET

# Media storage
# Current app can use local disk for development. Production should use S3/R2-compatible object storage.
MEDIA_STORAGE_DRIVER=s3
ATTACHMENT_STORAGE_DIR=./storage/attachments
SOCIAL_MEDIA_STORAGE_DIR=./storage/social
MAX_ATTACHMENT_BYTES=15728640
MAX_SOCIAL_MEDIA_BYTES=20971520
R2_ACCOUNT_ID=REPLACE_WITH_R2_ACCOUNT_ID
R2_ENDPOINT=https://REPLACE_WITH_R2_ACCOUNT_ID.r2.cloudflarestorage.com
R2_REGION=auto
R2_ACCESS_KEY_ID=REPLACE_WITH_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=REPLACE_WITH_R2_SECRET_ACCESS_KEY
R2_BUCKET=kryno-media
R2_PUBLIC_BASE_URL=https://media.kryno.example

# Paid subscriptions and monitoring
REVENUECAT_WEBHOOK_SECRET=REPLACE_WITH_REVENUECAT_WEBHOOK_SECRET
SENTRY_DSN=https://PUBLIC_KEY@o000000.ingest.sentry.io/PROJECT_ID
